{
  "id": "grimdark-space-opera",
  "name": "Grimdark Space Opera",
  "version": "2.0.0",
  "meta": {
    "category": "dark",
    "icon": "skull",
    "iconColor": "#c00000",
    "tags": ["gothic", "warhammer", "space", "dark", "imperial", "epic"],
    "description": "In the grim darkness of the far future, there is only profit. Blood red and imperial gold on the void of space."
  },
  "background": {
    "image": "/images/backgrounds/grimdark-void.jpg",
    "overlay": "linear-gradient(180deg, rgba(0,0,0,0.85) 0%, rgba(20,5,5,0.9) 50%, rgba(0,0,0,0.95) 100%)",
    "position": "center",
    "size": "cover",
    "attachment": "fixed"
  },
  "variables": {
    "bg-primary": "rgba(5, 2, 8, 0.95)",
    "bg-secondary": "rgba(15, 8, 12, 0.9)",
    "bg-tertiary": "rgba(25, 12, 18, 0.85)",
    "bg-code": "rgba(10, 5, 8, 0.95)",

    "text-primary": "#e8d5c4",
    "text-secondary": "#b8a090",
    "text-muted": "#6a5a4a",
    "text-inverted": "#0a0408",

    "border-primary": "#4a2020",
    "border-secondary": "#2a1010",

    "accent": "#c00000",
    "accent-hover": "#e01010",
    "accent-light": "#ff2020",
