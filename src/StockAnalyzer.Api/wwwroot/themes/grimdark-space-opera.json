    "chart-macd": "#c00000",
    "chart-macd-signal": "#6a5a4a",
    "chart-stochastic": "#d4af37",
    "chart-stochastic-d": "#b8860b",

    "chart-overbought": "rgba(192, 0, 0, 0.3)",
