  "effects": {
    "vignette": {
      "enabled": true,
      "strength": 0.7
    },
    "scanlines": {
      "enabled": true,
      "opacity": 0.06,
      "spacing": 3
    },
    "bloom": {
      "enabled": true,
      "contrast": 1.1,
      "brightness": 1.02
    }
  },
  "fonts": {
    "primary": "'Cinzel', 'Trajan Pro', 'Times New Roman', serif",
    "mono": "'Fira Code', 'Consolas', monospace"
  },
  "audio": {
    "key": "A",
    "mode": "harmonic_minor",
    "chordProgression": ["i", "bVI", "bVII", "V"],
    "chordVoicing": "power",
    "tempo": 0,
    "chordDuration": 16,
    "octave": 2,
    "texture": "drone",
    "oscillator": "sawtooth",
    "detune": 1.008,
    "filterCutoff": {
      "min": 200,
      "max": 600
    },
    "reverb": {
      "duration": 8,
      "decay": 4,
      "wetDry": 0.8
    },
    "pitchShift": 0.6,
    "style": "industrial"
  }
}
