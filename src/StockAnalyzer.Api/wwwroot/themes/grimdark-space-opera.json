    "chart-line-glow": "drop-shadow(0 0 4px rgba(192, 0, 0, 0.6))",
    "chart-line-glow-color": "#c00000",
    "chart-line-glow-width": "4px",

    "chart-marker-up": "#3d8a3d",
    "chart-marker-down": "#c00000",
    "chart-marker-up-outline": "#5daa5d",
    "chart-marker-down-outline": "#e02020",
    "chart-marker-symbol": "diamond",
    "chart-marker-size": "10",

    "grid-dot": "#2a1010",
    "grid-dot-active": "#d4af37",

    "zoom-bg": "rgba(192, 0, 0, 0.2)",
    "zoom-border": "#800000",

    "measure-bg": "rgba(212, 175, 55, 0.15)",
    "measure-line": "#d4af37",

    "placeholder-bg": "rgba(15, 8, 12, 0.8)",
    "placeholder-border": "#4a2020",

    "locked-pattern": "repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(192, 0, 0, 0.05) 10px, rgba(192, 0, 0, 0.05) 20px)"
