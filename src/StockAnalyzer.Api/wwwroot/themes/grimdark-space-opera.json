    "chart-line-secondary": "#d4af37",

    "chart-line-sma20": "#c00000",
    "chart-line-sma50": "#d4af37",
    "chart-line-sma200": "#6a5a4a",

    "chart-candle-up": "#3d8a3d",
    "chart-candle-down": "#c00000",

    "chart-volume-up": "rgba(61, 138, 61, 0.6)",
    "chart-volume-down": "rgba(192, 0, 0, 0.6)",

