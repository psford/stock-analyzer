    "price-up": "#3d8a3d",
    "price-up-glow": "0 0 8px rgba(61, 138, 61, 0.5)",
    "price-down": "#c00000",
    "price-down-glow": "0 0 8px rgba(192, 0, 0, 0.5)",

    "audio-active-bg": "rgba(192, 0, 0, 0.3)",

    "music-active-color": "#d4af37",
    "music-active-bg": "rgba(212, 175, 55, 0.2)",
    "music-active-glow": "0 0 15px rgba(212, 175, 55, 0.5)",
    "viz-bar-color": "#c00000",
    "viz-bar-glow": "0 0 6px rgba(192, 0, 0, 0.7)",

    "btn-primary-bg": "linear-gradient(180deg, #c00000 0%, #800000 100%)",
