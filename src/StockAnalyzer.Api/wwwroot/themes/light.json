    "shadow-xl": "0 25px 50px -12px rgba(0,0,0,0.2)",

    "radius-sm": "0.25rem",
    "radius-md": "0.375rem",
    "radius-lg": "0.5rem",

    "tile-title-color": "#111827",
    "tile-title-transform": "none",
    "tile-title-spacing": "normal",
    "tile-title-weight": "600",
    "tile-title-glow": "none",

    "chart-bg": "#ffffff",
    "chart-text": "#1f2937",
    "chart-grid": "#e5e7eb",
    "chart-axis": "#6b7280",
    "chart-line-primary": "#3b82f6",
    "chart-line-secondary": "#f59e0b",
    "chart-line-sma20": "#f59e0b",
    "chart-line-sma50": "#8b5cf6",
    "chart-line-sma200": "#ec4899",
    "chart-candle-up": "#10b981",
    "chart-candle-down": "#ef4444",
    "chart-volume-up": "#065f46",
    "chart-volume-down": "#991b1b",
    "chart-rsi": "#8b5cf6",
    "chart-macd": "#3b82f6",
    "chart-macd-signal": "#f59e0b",
    "chart-stochastic": "#14b8a6",
    "chart-stochastic-d": "#f59e0b",
    "chart-overbought": "#ef4444",
    "chart-oversold": "#10b981",
    "chart-bollinger": "#6366f1",
    "chart-line-glow": "none",
    "chart-line-glow-color": "transparent",
    "chart-line-glow-width": "0",
    "chart-marker-up": "#10b981",
    "chart-marker-down": "#ef4444",
    "chart-marker-up-outline": "#065f46",
    "chart-marker-down-outline": "#991b1b",
    "chart-marker-symbol": "triangle",
    "chart-marker-size": "22",

    "grid-dot": "#d1d5db",
    "grid-dot-active": "rgba(59,130,246,0.35)",

    "zoom-bg": "rgba(245, 158, 11, 0.1)",
    "zoom-border": "rgba(245, 158, 11, 0.6)",

    "measure-bg": "rgba(59, 130, 246, 0.08)",
    "measure-line": "rgba(59, 130, 246, 0.8)",

    "placeholder-bg": "rgba(59,130,246,0.08)",
    "placeholder-border": "rgba(59,130,246,0.3)",

    "locked-pattern": "rgba(0,0,0,0.015)"
