{
  "id": "light",
  "name": "Light",
  "version": "1.0.0",
  "meta": {
    "category": "light",
    "icon": "sun",
    "iconColor": "#f59e0b"
  },
  "variables": {
    "bg-primary": "#ffffff",
    "bg-secondary": "#f9fafb",
    "bg-tertiary": "#f3f4f6",
    "bg-code": "#1f2937",

    "text-primary": "#111827",
    "text-secondary": "#374151",
    "text-muted": "#6b7280",
    "text-inverted": "#e5e7eb",

    "border-primary": "#e5e7eb",
    "border-secondary": "#d1d5db",

    "accent": "#3b82f6",
    "accent-hover": "#2563eb",
    "accent-light": "#60a5fa",
    "accent-bg": "rgba(59, 130, 246, 0.1)",
    "accent-bg-subtle": "rgba(59, 130, 246, 0.05)",

    "success": "#059669",
    "error": "#dc2626",
    "warning": "#d97706",
    "warning-light": "#fbbf24",

    "highlight-bg": "#fef08a",
    "highlight-text": "#854d0e",

    "danger-bg": "#fee2e2",
    "danger-border": "#fca5a5",

    "star-color": "#eab308",
