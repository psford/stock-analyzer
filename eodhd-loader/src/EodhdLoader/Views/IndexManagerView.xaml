<UserControl x:Class="EodhdLoader.Views.IndexManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EodhdLoader">
    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="iShares Constituent Loader" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 1: Load Configuration -->
        <GroupBox Grid.Row="1" Header="Load Configuration" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- As-of Date Row -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="As-of Date:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding AsOfDate}" Margin="0,0,20,0"/>

                <!-- ETF Selection Row -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="ETF:" VerticalAlignment="Center" Margin="0,10,10,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableEtfTickers}"
                          SelectedItem="{Binding SelectedEtfTicker}"
                          Margin="0,10,20,0"/>
            </Grid>
        </GroupBox>

        <!-- Row 2: Progress -->
        <GroupBox Grid.Row="2" Header="Progress" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Current ETF Label -->
                <TextBlock Grid.Row="0" Text="{Binding CurrentEtfLabel}" FontWeight="Bold" Margin="0,0,0,5"/>

                <!-- Progress Bar -->
                <ProgressBar Grid.Row="1" Value="{Binding Progress}" Minimum="0" Maximum="100"
                             Height="25" Margin="0,0,0,5"/>

                <!-- Progress Stats -->
                <TextBlock Grid.Row="2" Text="{Binding ProgressText}" Foreground="#666" FontSize="11" Margin="0,0,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Row 3: Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
            <Button Content="Clear Log" Command="{Binding ClearLogCommand}" Width="80" Height="30" Margin="0,0,10,0"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80" Height="30" Margin="0,0,10,0"
                    IsEnabled="{Binding IsLoading}"/>
            <Button Content="Load" Command="{Binding LoadAllCommand}" Width="80" Height="30"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>

        <!-- Row 4: Activity Log -->
        <GroupBox Grid.Row="4" Header="Activity Log" Margin="0,0,0,0">
            <ListBox ItemsSource="{Binding LogMessages}" FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Row 5: Reserved for future use -->
    </Grid>
</UserControl>
